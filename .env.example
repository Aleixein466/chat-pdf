APP_NAME=ChatPDF Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/chatpdf
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3
OLLAMA_TIMEOUT=300

CHUNK_SIZE=800
CHUNK_OVERLAP=200
TOP_K=3
UPLOAD_DIR=storage/uploads
